# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=booking_care

# GROQ API Configuration (for AI Doctor Chatbot)
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Alternative models:
# GROQ_MODEL=llama-3.1-8b-instant (faster, less accurate)
# GROQ_MODEL=llama-3.1-405b-reasoning (slower, more accurate)
# GROQ_MODEL=mixtral-8x7b-32768 (good balance)

# RAG Configuration
RAG_CONTEXT_DOCS=8

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Other API Keys (if using)
OPENAI_API_KEY=sk_your_openai_key_here (optional, for ChatGPT integration)
